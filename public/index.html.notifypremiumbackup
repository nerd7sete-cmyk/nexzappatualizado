
<!DOCTYPE html>
<html lang="pt-BR">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>NEXZAPP</title>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"/>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Inter',sans-serif;
}

body{

background:
linear-gradient(
180deg,
#02040b,
#050816,
#02040b
);

color:white;

height:100dvh;
overflow:hidden;

}

/* HEADER */

.header{

height:72px;

display:flex;
align-items:center;
justify-content:space-between;

padding:0 22px;

background:
rgba(6,10,24,.96);

border-bottom:
1px solid rgba(255,255,255,.05);

backdrop-filter:blur(16px);

}

.logo{

font-size:30px;
font-weight:800;

background:
linear-gradient(
90deg,
#25D366,
#7CFC00
);

-webkit-background-clip:text;
-webkit-text-fill-color:transparent;

}

.status{

display:flex;
align-items:center;
gap:8px;

padding:10px 14px;

border-radius:14px;

background:
rgba(37,211,102,.10);

border:
1px solid rgba(37,211,102,.15);

font-size:11px;
font-weight:700;

color:#25D366;

}

.dot{

width:8px;
height:8px;

border-radius:50%;

background:#25D366;

box-shadow:
0 0 12px #25D366;

}

/* MAIN */

.main{

height:calc(100dvh - 72px);

overflow:auto;

padding:14px;
padding-bottom:40px;

}

/* GRID */

.grid{

display:grid;

grid-template-columns:1fr 1fr;

gap:14px;

}

/* CARD */

.card{

position:relative;

padding:20px;

min-height:150px;

border-radius:30px;

overflow:hidden;

cursor:pointer;

transition:.25s;

background:
linear-gradient(
180deg,
rgba(17,24,39,.98),
rgba(10,14,28,.99)
);

border:
1px solid rgba(255,255,255,.05);

display:flex;
flex-direction:column;
justify-content:space-between;

}

.card:hover{

transform:translateY(-3px);

border:
1px solid rgba(37,211,102,.22);

}

.card::before{

content:'';

position:absolute;

top:-70px;
right:-70px;

width:180px;
height:180px;

background:
radial-gradient(
circle,
rgba(37,211,102,.10),
transparent
);

}

.icon{

width:52px;
height:52px;

border-radius:20px;

display:flex;
align-items:center;
justify-content:center;

background:
rgba(37,211,102,.10);

color:#25D366;

font-size:22px;

margin-bottom:16px;

}

.card h2{

font-size:20px;
font-weight:800;

margin-bottom:10px;

}

.card p{

font-size:13px;

line-height:1.7;

opacity:.6;

}

.action{

display:flex;
align-items:center;
justify-content:space-between;

margin-top:18px;

font-size:12px;
font-weight:700;

}

/* MODAL */

.modal{

position:fixed;

inset:0;

background:
rgba(0,0,0,.84);

backdrop-filter:blur(14px);

display:none;

z-index:999;

}

.modal.active{

display:block;

}

.modal-box{

position:absolute;

inset:0;

overflow:auto;

padding:22px;
padding-bottom:120px;

background:
linear-gradient(
180deg,
#040816,
#02040b
);

}

/* MODAL HEADER */

.modal-header{

display:flex;
align-items:center;
justify-content:space-between;

margin-bottom:24px;

}

.modal-header h2{

font-size:28px;
font-weight:800;

}

.close{

width:44px;
height:44px;

border:none;

border-radius:16px;

background:
rgba(255,255,255,.05);

color:white;

font-size:16px;

cursor:pointer;

}

/* CONNECTED */

.connected{

display:flex;
flex-direction:column;
align-items:center;
justify-content:center;

padding:50px 20px;

}

.connected-icon{

width:100px;
height:100px;

border-radius:30px;

display:flex;
align-items:center;
justify-content:center;

background:
rgba(37,211,102,.12);

font-size:42px;

color:#25D366;

margin-bottom:24px;

box-shadow:
0 0 40px rgba(37,211,102,.18);

}

.connected h3{

font-size:28px;
font-weight:800;

margin-bottom:10px;

}

.connected p{

font-size:14px;

opacity:.6;

margin-bottom:26px;

}

/* QR */

.qr{

width:260px;
height:260px;

background:white;

border-radius:26px;

padding:10px;

display:flex;
align-items:center;
justify-content:center;

margin:auto;

margin-top:30px;

}

.qr img{

width:100%;
height:100%;

object-fit:contain;

}

/* INPUT */

textarea,
input{

width:100%;

background:
rgba(255,255,255,.03);

border:none;
outline:none;

padding:16px;

border-radius:18px;

color:white;

margin-bottom:14px;

font-size:13px;

border:
1px solid rgba(255,255,255,.05);

}

textarea{

height:150px;
resize:none;

}

.file{

padding:14px;

border-radius:18px;

background:
rgba(255,255,255,.03);

border:
1px dashed rgba(255,255,255,.08);

margin-bottom:16px;

}

/* BUTTON */

.btn{

width:100%;
height:52px;

border:none;
outline:none;

border-radius:18px;

background:
linear-gradient(
90deg,
#25D366,
#7CFC00
);

color:black;

font-size:14px;
font-weight:800;

cursor:pointer;

transition:.25s;

}

.btn:hover{

transform:translateY(-2px);

box-shadow:
0 10px 25px rgba(37,211,102,.18);

}

/* GROUPS */

.groups{

display:flex;
flex-direction:column;

gap:14px;

margin-bottom:22px;

max-height:340px;

overflow:auto;

padding-right:4px;

}

.group{

padding:16px 18px;

border-radius:22px;

background:
linear-gradient(
180deg,
rgba(17,24,39,.95),
rgba(15,23,42,.98)
);

display:flex;
align-items:center;
justify-content:space-between;

border:
1px solid rgba(255,255,255,.05);

}

.group-left{

display:flex;
align-items:center;

gap:14px;

flex:1;

min-width:0;

}

.group input{

width:18px;
height:18px;

min-width:18px;

accent-color:#25D366;

}

.group-name{

font-size:14px;
font-weight:600;

white-space:nowrap;
overflow:hidden;
text-overflow:ellipsis;

}

.group-status{

font-size:11px;
font-weight:700;

color:#25D366;

padding:8px 12px;

border-radius:12px;

background:
rgba(37,211,102,.10);

border:
1px solid rgba(37,211,102,.15);

}

/* PROGRESS */

.progress{

margin-top:18px;

padding:14px;
padding-bottom:40px;

border-radius:22px;

background:
rgba(255,255,255,.03);

border:
1px solid rgba(255,255,255,.05);

}

.bar{

width:100%;
height:10px;

border-radius:20px;

overflow:hidden;

background:
rgba(255,255,255,.05);

margin-top:12px;

}

.bar div{

width:0%;

height:100%;

background:
linear-gradient(
90deg,
#25D366,
#7CFC00
);

transition:.3s;

}

@media(max-width:700px){

.grid{
grid-template-columns:1fr;
}

}

</style>

</head>

