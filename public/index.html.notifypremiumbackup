})

const data =
await res.json()

if(data.success){

document
.getElementById('adminStatus')
.innerHTML =
'✓ Usuário criado com sucesso'

loadUsers()

}else{

document
.getElementById('connectContent')
.dataset.connected = 'false'

document
.getElementById('adminStatus')
.innerHTML =
'Erro ao criar usuário'

}

}

async function loadUsers(){

const token =
localStorage.getItem('token')

const res =
await fetch('/users',{

headers:{
authorization:token
}

})

const users =
await res.json()

const list =
document.getElementById('usersList')

list.innerHTML=''

users.forEach(user=>{

list.innerHTML += `

<div class="group">

<div class="group-left">

<div class="group-name">
${user.user}
</div>

</div>

<button
class="btn"
style="
width:120px;
height:42px;
border-radius:14px;
font-size:12px;
"
onclick="deleteUser('${user.user}')"
>
REMOVER
</button>

</div>

`

})

}

async function deleteUser(user){

const token =
localStorage.getItem('token')

await fetch('/delete-user',{

method:'POST',

headers:{
'Content-Type':'application/json',
authorization:token
},

body:JSON.stringify({
user
})

})

loadUsers()

}

loadAdmin()

