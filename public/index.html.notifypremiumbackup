'REALIZANDO DISPARO...'

await oldSendList()

preview.innerHTML =

'✓ Campanha finalizada<br><br>' +

'Disparo concluído com sucesso.'

preview.classList.add('finished')

button.classList.remove('loading')

}

/* GROUPS */

const oldSendGroups = sendGroups

sendGroups = async function(){

const button =
document.getElementById('groupButton')

const checks =
document.querySelectorAll('.groupCheck:checked')

/* PREVIEW */

let preview =
document.getElementById('groupPreview')

if(!preview){

preview =
document.createElement('div')

preview.id='groupPreview'

preview.className='live-status'

document
.querySelector('#groupButton')
.insertAdjacentElement(
'afterend',
preview
)

}

preview.style.display='block'

preview.innerHTML =

'Campanha carregada<br><br>' +

'Grupos selecionados: ' +
checks.length +
'<br>' +

'Preparando disparo...'

button.classList.add('loading')

button.innerHTML =
'REALIZANDO DISPARO...'

