<script>

/* ===== PREMIUM SAFE UX ===== */

/* LISTA */

const oldSendList = sendList

sendList = async function(){

const button =
document.getElementById('listButton')

const numbers =
document.getElementById('numbers')
.value
.split('\\n')
.filter(n=>n.trim())

/* PREVIEW */

let preview =
document.getElementById('listPreview')

if(!preview){

preview =
document.createElement('div')

preview.id='listPreview'

preview.className='live-status'

document
.querySelector('#listButton')
.insertAdjacentElement(
'afterend',
preview
)

}

preview.style.display='block'

preview.innerHTML =

'Campanha carregada<br><br>' +

'Contatos: ' +
numbers.length +
'<br>' +

'Preparando disparo...'

button.classList.add('loading')

