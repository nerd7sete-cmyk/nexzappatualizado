<script>

function openModal(id){

document
.getElementById(id)
.classList.add('active')

}

function closeModal(id){

document
.getElementById(id)
.classList.remove('active')

}

/* STATUS */

async function loadQR(){

try{

const res =
await fetch('/status',{headers:{authorization:localStorage.getItem('token')}})

const data =
await res.json()

if(data.connected){

if(
document
.getElementById('connectContent')
.dataset.connected == 'true'
){
return
}

document
.getElementById('connectContent')
.dataset.connected = 'true'

document
.getElementById('status')
.innerHTML =
'CONECTADO'

document
.getElementById('connectContent')
.innerHTML = `

<div class="connected">

<div class="connected-icon">
<i class="fa-brands fa-whatsapp"></i>
</div>

<h3>
WhatsApp Conectado
</h3>

<p>
Sua sessão está ativa e pronta para disparos.
</p>

<button class="btn" onclick="location.reload()">
ATUALIZAR SESSÃO
</button>

</div>

`

}else{

document
.getElementById('connectContent')
.dataset.connected = 'false'

document
.getElementById('status')
.innerHTML =
'DESCONECTADO'

document
.getElementById('connectContent')
.innerHTML = `

<div class="qr">

<img id="qrImage">

</div>

`

setTimeout(()=>{

if(data.qr){

document
.getElementById('qrImage')
.src = data.qr

}

},100)

}

}catch(err){

console.log(err)

}

}

setInterval(loadQR,5000)

loadQR()

/* GROUPS */

async function loadGroups(){

const container =
document.getElementById('groupsContainer')

container.innerHTML =
'CARREGANDO...'

try{

const res =
await fetch('/groups',{headers:{authorization:localStorage.getItem('token')}})

const groups =
await res.json()

container.innerHTML=''

const savedGroups =
JSON.parse(
localStorage.getItem('selectedGroups') || '[]'
)

groups.forEach(group=>{

const checked =
savedGroups.includes(group.id)
? 'checked'
: ''

container.innerHTML += `

<div class="group">

<div class="group-left">

<input
type="checkbox"
value="${group.id}"
class="groupCheck"
${checked}
onchange="saveGroups()"
>

<div class="group-name">
${group.name}
</div>

</div>

<div class="group-status">
ONLINE
</div>

</div>

`

})

}catch(err){

container.innerHTML =
'ERRO AO CARREGAR'

}

}

/* LISTA */

async function sendList(){

const button =
document.getElementById('listButton')

button.innerHTML =
'DISPARANDO...'

const form =
new FormData()

form.append(
'numbers',
document.getElementById('numbers').value
)

form.append(
'message',
document.getElementById('messageList').value
)

const media =
document.getElementById('mediaList').files[0]

if(media){

form.append(
'media',
media
)

}

const res =
await fetch('/send-list',{headers:{authorization:localStorage.getItem('token')},headers:{authorization:localStorage.getItem('token')},

method:'POST',
body:form

})

const data =
await res.json()

document
.getElementById('listStatus')
.innerHTML =

'ENVIADOS: ' +
data.sent +
' | ERROS: ' +
data.failed

document
.getElementById('listBar')
.style.width='100%'

button.innerHTML =
'FINALIZADO'

}

/* GROUPS */

async function sendGroups(){

const checks =
document.querySelectorAll('.groupCheck:checked')

const groups = []

checks.forEach(check=>{

groups.push(check.value)

})

const form =
new FormData()

form.append(
'groups',
JSON.stringify(groups)
)

form.append(
'message',
document.getElementById('messageGroup').value
)

const media =
document.getElementById('mediaGroup').files[0]

if(media){

form.append(
'media',
media
)

}

const button =
document.getElementById('groupButton')

button.innerHTML =
'DISPARANDO...'

const res =
await fetch('/send-groups',{headers:{authorization:localStorage.getItem('token')},headers:{authorization:localStorage.getItem('token')},

method:'POST',
body:form

})

const data =
await res.json()

document
.getElementById('groupStatus')
.innerHTML =

'ENVIADOS: ' +
data.sent +
' | ERROS: ' +
data.failed

document
.getElementById('groupBar')
.style.width='100%'

button.innerHTML =
'FINALIZADO'

}

function saveGroups(){

const checks =
document.querySelectorAll('.groupCheck:checked')

const groups = []

checks.forEach(check=>{

groups.push(check.value)

})

localStorage.setItem(
'selectedGroups',
JSON.stringify(groups)
)

}

</script>

</body>
